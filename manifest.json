{
  "manifest_version": 3,
  "name": "Zoho Deluge Formatter",
  "version": "1.2",
  "description": "Formats Zoho Deluge code, detects errors in real-time, and integrates AI assistance.",

  "permissions": [
    "scripting",
    "activeTab",
    "tabs",
    "storage"
  ],

  "host_permissions": [
    "https://*.zoho.com/*",
    "https://*.zoho.in/*",
    "https://*.zoho.eu/*",
    "https://*.zoho.com.au/*",
    "https://*.zohoapis.com/*",
    "https://*.zohoapis.in/*",
    "https://api.anthropic.com/*",
    "https://api.x.ai/*",
    "https://generativelanguage.googleapis.com/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_title": "Deluge Formatter Settings",
    "default_popup": "popup.html"
  }
}