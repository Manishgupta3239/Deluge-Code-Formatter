{
  "manifest_version": 3,
  "name": "Zoho Deluge Formatter",
  "version": "1.1",
  "description": "Formats Zoho Deluge code and detects missing semicolons in real-time.",

  "permissions": [
    "scripting",
    "activeTab",
    "tabs"
  ],

  "host_permissions": [
    "https://*.zoho.com/*",
    "https://*.zohoapis.com/*",
    "https://*.zoho.in/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_title": "Format Deluge Code"
  }
}